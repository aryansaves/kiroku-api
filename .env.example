# ─────────────────────────────────────
# Kiroku API — Environment Variables
# ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Required vars are marked [required].

NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────
# MongoDB Atlas connection string [required]
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/kiroku

# ── Redis ─────────────────────────────
# Upstash Redis or local Redis URL [required]
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────
# JWT signing secret — at least 32 characters [required]
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Telegram ──────────────────────────
# Bot token from @BotFather [required]
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ── Bot Internal ──────────────────────
# Shared secret between bot and internal API [required]
BOT_INTERNAL_SECRET=random-string-for-internal-routes

# ── LLM / NLP ─────────────────────────
# Groq API key for natural language parsing [required]
LLM_API_KEY=gsk_your-groq-api-key

# ── Metadata APIs ─────────────────────
# TMDB API key (movies/series) — optional, falls back to OMDB
TMDB_API_KEY=
# OMDB API key (movies/series) [required]
OMDB_API_KEY=your-omdb-api-key
# ComicVine API key (comics) — optional
COMICVINE_API_KEY=

# ── CORS ──────────────────────────────
# Allowed origin for CORS. Defaults to "*" (all origins)
CORS_ORIGIN=*

# ── Feature Flags ─────────────────────
# Enable the Telegram bot (set to true if running the bot process)
ENABLE_BOT=false
# Enable dev auth bypass (only in development!)
ENABLE_DEV_AUTH=false

# ── Google OAuth (optional) ───────────
# Leave blank to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend URL ──────────────────────
# Publicly-accessible frontend URL (for OAuth redirects)
APP_URL=http://localhost:3001
